#!/usr/bin/env bash
set -euo pipefail

if ! command -v mise >/dev/null 2>&1; then
  echo "pre-push: mise is required to run Hive's local CI checks." >&2
  echo "pre-push: install mise, then run: mise install && mise run hooks:install" >&2
  exit 1
fi

echo "pre-push: ensuring mise tools are installed"
mise install

echo "pre-push: running local CI checks"
mise run ci
